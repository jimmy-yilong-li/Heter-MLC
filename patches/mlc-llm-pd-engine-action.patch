+/****************** ExternalKVDataNode ******************/
+
+/*!
+ * \brief Externally produced K/V data for PD-split cache injection.
+ *
+ * The producer must emit tensors in the same convention consumed by Model::DebugSetKV.
+ * For kNormal RoPE models, K must already be rotary-applied at absolute positions
+ * [0, prefill_length); V is always raw. This path is currently intended for plain-MHA
+ * models; sliding-window and MLA models are not supported by the injection runtime.
+ */
+class ExternalKVDataNode : public DataNode {
+ public:
+  /*! \brief K data in layout (num_layers, prefill_length, num_kv_heads, head_dim). */
+  Tensor k_data;
+  /*! \brief V data in layout (num_layers, prefill_length, num_kv_heads, head_dim). */
+  Tensor v_data;
+  /*! \brief Number of externally-prefilled tokens represented by K/V. */
+  int prefill_length;
+  /*! \brief Already sampled token ids to feed into the first engine-driven decode step. */
+  Shape decode_token_ids;
+
+  int GetLength() const final;
+  ObjectRef GetEmbedding(Model model, ObjectRef* dst = nullptr, int offset = 0) const final;
+
+  static void RegisterReflection() {
+    namespace refl = tvm::ffi::reflection;
+    refl::ObjectDef<ExternalKVDataNode>();
+  }
+
+  TVM_FFI_DECLARE_OBJECT_INFO_FINAL("mlc.serve.ExternalKVData", ExternalKVDataNode, DataNode);
+};
+
+class ExternalKVData : public Data {
+ public:
+  explicit ExternalKVData(Tensor k_data, Tensor v_data, int prefill_length, Shape decode_token_ids);
+
+  TVM_FFI_DEFINE_OBJECT_REF_METHODS_NULLABLE(ExternalKVData, Data, ExternalKVDataNode);
+};
+
+inline bool ContainsExternalKVData(const Array<Data>& inputs) {
+  for (const Data& input : inputs) {
+    if (input.as<ExternalKVDataNode>() != nullptr) {
+      return true;
+    }
+  }
+  return false;
+}
+
+inline const ExternalKVDataNode* GetSoleExternalKVData(const Array<Data>& inputs) {
+  if (inputs.size() != 1) {
+    return nullptr;
+  }
+  return inputs[0].as<ExternalKVDataNode>();
+}
