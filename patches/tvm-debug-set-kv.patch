+  /*!
+   * \brief Build the full logical-token to physical-page position map for debug KV I/O.
+   *
+   * The sink/sliding-window offset formula here is the single source of truth shared by
+   * DebugGetKV, DebugGetKVMLA, and DebugSetKV. The returned vector has one entry per logical
+   * token in the sequence, and each entry is a flattened physical slot
+   * `page_id * page_size + page_offset`.
+   */
+  std::vector<int32_t> BuildPhysicalPositionMap(const Sequence& seq) const {
+    std::vector<int32_t> trace = seq.GetBlockTrace(global_block_pool_);
+    std::vector<int32_t> position_map;
+    position_map.reserve(seq.seq_length);
+    for (int32_t block_id : trace) {
+      const Block& block = global_block_pool_[block_id];
+      for (int i = 0; i < block.seq_length; ++i) {
+        int32_t offset =
+            i < block.sink_length ? i : i - block.sink_length + block.sliding_window_offset;
+        int page_id = block.page_ids[offset / page_size_];
+        int page_offset = offset % page_size_;
+        position_map.push_back(page_id * page_size_ + page_offset);
+      }
+    }
+    TVM_FFI_ICHECK_EQ(static_cast<int64_t>(position_map.size()), seq.seq_length);
+    return position_map;
+  }
+
+  /*!
+   * \brief Copy a contiguous logical-token window from a host position map to the cache device.
+   *
+   * The window is expressed in logical token positions. Bounds are checked on host before the
+   * auxiliary tensor is created on `device_`.
+   */
+  Tensor CopyPositionMapWindowToDevice(const std::vector<int32_t>& position_map, int64_t start_pos,
+                                       int64_t length) const {
+    TVM_FFI_ICHECK_GE(start_pos, 0);
+    TVM_FFI_ICHECK_GE(length, 0);
+    TVM_FFI_ICHECK_LE(start_pos + length, static_cast<int64_t>(position_map.size()));
+    Tensor position_map_device = Tensor::Empty({length}, dtype_aux_, device_);
+    position_map_device.CopyFromBytes(position_map.data() + start_pos,
+                                      length * ((dtype_aux_.bits * dtype_aux_.lanes + 7) / 8));
+    return position_map_device;
+  }
